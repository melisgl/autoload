;;;; -*- mode: Lisp -*-

;;;; The extension of this file is "system" to prevent e.g.
;;;; QL:REGISTER-LOCAL-PROJECTS from picking it up.

(asdf:defsystem "%package-test"
  :depends-on ("autoload")
  :defsystem-depends-on ("autoload")
  :class "autoload:autoload-system"
  :auto-depends-on ("%package-test/full")
  :auto-loaddefs ("loaddefs.lisp" :packages #:%aaa)
  :serial t
  :components ((:file "loaddefs")))

(asdf:defsystem "%package-test/full"
  :depends-on ("autoload" "%package-test")
  :defsystem-depends-on ("autoload")
  :class "autoload:autoload-system"
  :serial t
  :components ((:file "full")))
