;;;; -*- mode: Lisp -*-

;;;; The extension of this file is "system" to prevent e.g.
;;;; QL:REGISTER-LOCAL-PROJECTS from picking it up.

(asdf:defsystem "%simple-test"
  :depends-on ("autoload")
  :defsystem-depends-on ("autoload")
  :class "autoload:autoload-system"
  :autoloaded-systems ("%simple-test/full")
  :record-autoloads "autoloads.lisp"
  :serial t
  :components ((:file "package")
               (:file "manual-autoloads")
               (:file "autoloads")))

(asdf:defsystem "%simple-test/full"
  :depends-on ("autoload" "%simple-test")
  :defsystem-depends-on ("autoload")
  :class "autoload:autoload-system"
  :serial t
  :components ((:file "full")))
