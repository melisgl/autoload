;;;; -*- mode: Lisp -*-

;;;; The extension of this file is "system" to prevent e.g.
;;;; QL:REGISTER-LOCAL-PROJECTS from picking it up.

(asdf:defsystem "%test-system"
  :depends-on ("autoload")
  :defsystem-depends-on ("autoload")
  :class "autoload:autoload-system"
  :auto-depends-on ("%test-system/full")
  :auto-loaddefs "loaddefs.lisp"
  :serial t
  :components ((:file "package")
               (:file "manual-loaddefs")
               (:file "loaddefs")))

(asdf:defsystem "%test-system/full"
  :depends-on ("autoload" "%test-system")
  :defsystem-depends-on ("autoload")
  :class "autoload:autoload-system"
  :serial t
  :components ((:file "full")))
